generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BusinessType {
  SCRAP_YARD
  DEMOLITION
  SHIP_BREAKER
  MANUFACTURER
  RECYCLER
  TRADER
  BROKER
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum ListingType {
  SELL
  BUY
  WANTED
  AUCTION
}

enum MaterialCategory {
  FERROUS_METALS
  NON_FERROUS_METALS
  ENGINES_DRIVETRAIN
  ELECTRIC_MOTORS
  PIPING_FITTINGS
  TANKS_VESSELS
  HEAVY_MACHINERY
  MARINE_OFFSHORE
  RAIL_TRANSPORT
  AEROSPACE
  CONSTRUCTION_DEMOLITION
  ELECTRONIC_ELECTRICAL
  PRECIOUS_SPECIALTY
  INDUSTRIAL_EQUIPMENT
}

enum Condition {
  COMPLETE
  PARTIAL
  DAMAGED
  AS_IS
  SCRAP_ONLY
}

enum Unit {
  TONS
  LBS
  KG
  PIECES
  LOT
}

enum ListingStatus {
  ACTIVE
  EXPIRED
  SOLD
  DRAFT
}

enum InquiryStatus {
  PENDING
  RESPONDED
  CLOSED
}

enum RFQStatus {
  OPEN
  CLOSED
  AWARDED
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  businessType       BusinessType
  verificationStatus VerificationStatus @default(UNVERIFIED)
  ein                String?
  licenseNumber      String?
  address            String?
  city               String
  state              String
  country            String             @default("US")
  zipCode            String?
  phone              String?
  email              String
  website            String?
  description        String?
  logoUrl            String?
  memberSince        DateTime           @default(now())
  rating             Float              @default(0)
  reviewCount        Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  listings          Listing[]
  sentInquiries     Inquiry[]   @relation("InquiryFrom")
  receivedInquiries Inquiry[]   @relation("InquiryTo")
  rfqs              RFQ[]
  reviewsGiven      Review[]    @relation("ReviewFrom")
  reviewsReceived   Review[]    @relation("ReviewTo")
  users             User[]
}

model Listing {
  id                  String           @id @default(cuid())
  companyId           String
  company             Company          @relation(fields: [companyId], references: [id])
  listingType         ListingType
  title               String
  materialCategory    MaterialCategory
  materialSubcategory String?
  grade               String?
  condition           Condition
  quantity            Float
  unit                Unit
  pricePerUnit        Float?
  currency            String           @default("USD")
  negotiable          Boolean          @default(false)
  minOrder            Float?
  description         String?
  specs               String?
  location            String?
  city                String
  state               String
  country             String           @default("US")
  pickupAvailable     Boolean          @default(true)
  deliveryAvailable   Boolean          @default(false)
  expiresAt           DateTime?
  status              ListingStatus    @default(ACTIVE)
  viewCount           Int              @default(0)
  inquiryCount        Int              @default(0)
  photos              String[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  inquiries Inquiry[]
}

model Inquiry {
  id            String        @id @default(cuid())
  listingId     String
  listing       Listing       @relation(fields: [listingId], references: [id])
  fromCompanyId String
  fromCompany   Company       @relation("InquiryFrom", fields: [fromCompanyId], references: [id])
  toCompanyId   String
  toCompany     Company       @relation("InquiryTo", fields: [toCompanyId], references: [id])
  message       String
  contactName   String
  contactPhone  String?
  contactEmail  String
  status        InquiryStatus @default(PENDING)
  createdAt     DateTime      @default(now())
}

model RFQ {
  id                  String           @id @default(cuid())
  companyId           String
  company             Company          @relation(fields: [companyId], references: [id])
  title               String
  materialCategory    MaterialCategory
  materialSubcategory String?
  quantityNeeded      Float
  unit                Unit
  targetPrice         Float?
  deliveryLocation    String?
  neededBy            DateTime?
  description         String?
  status              RFQStatus        @default(OPEN)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model Review {
  id              String   @id @default(cuid())
  fromCompanyId   String
  fromCompany     Company  @relation("ReviewFrom", fields: [fromCompanyId], references: [id])
  toCompanyId     String
  toCompany       Company  @relation("ReviewTo", fields: [toCompanyId], references: [id])
  rating          Int
  comment         String?
  transactionType String?
  createdAt       DateTime @default(now())
}

model SavedSearch {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  filters      Json
  alertEnabled Boolean   @default(false)
  lastAlerted  DateTime?
  createdAt    DateTime  @default(now())
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  companyId     String?
  company       Company?      @relation(fields: [companyId], references: [id])
  accounts      Account[]
  sessions      Session[]
  savedSearches SavedSearch[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
